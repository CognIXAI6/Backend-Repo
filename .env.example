# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# Database
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# Email - Resend
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email - Nodemailer (fallback)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Email Settings
EMAIL_FROM=
EMAIL_FROM_NAME=

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3001

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create recurring prices in the Stripe dashboard and paste the price IDs here.
# These are the default price IDs used unless overridden per-row in the subscription_plans table.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_QUARTERLY=
STRIPE_PRICE_BIANNUAL=
STRIPE_PRICE_YEARLY=

# Clerk (OAuth / social login)
# Get these from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Voice Verification Service (speaker biometrics)
# Base URL without trailing slash — e.g. https://voice-api.example.com
VOICE_VERIFICATION_URL=http://localhost:8000
